{
  "appId": "com.hardylab.checkit",
  "productName": "Checkit Codebase Doctor",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "out/**/*",
    "electron/main.cjs",
    "electron/preload.cjs",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../packages/backend/dist",
      "to": "checkit-cli"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": "dmg",
    "icon": "build/icon.icns"
  },
  "linux": {
    "target": "AppImage",
    "icon": "build/icon.png"
  }
}