# LintAny / Checkit CLI — Environment Variables
#
# Copy this file to `.env` (gitignored) or export directly in your shell.
# Run `pnpm exec checkit doctor` afterwards to verify which keys are picked up.
#
# At least ONE provider key is required for cloud-backed `lintany chat`.
# Without any key, `lintany chat` falls back to local keyword matching
# (still useful — returns rule/preset suggestions based on keywords,
# but the reply text is templated, not LLM-generated).

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MiniMax (default provider — OpenAI-compatible)
# Get a key: https://api.minimaxi.com/
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
MINIMAX_API_KEY=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OpenAI (alternative — gpt-4o-mini / gpt-4o / etc.)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1   # default; override for Azure/Together/OpenRouter
# OPENAI_MODEL=gpt-4o-mini                   # default

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Anthropic Claude (alternative)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5          # default

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Choosing adapter (priority order — see `lintany chat` source for details)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. --adapter flag (explicit)            lintany chat --adapter minimax
# 2. ~/.checkit/config.json ai.adapter    lintany config set ai.adapter minimax
# 3. env var auto-promotion:
#    MINIMAX_API_KEY      → minimax
#    OPENAI_API_KEY       → openai
#    ANTHROPIC_API_KEY    → claude
# 4. local-keyword (offline fallback — keyword-based suggestions)

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Per-adapter config override
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Override model / baseUrl without changing adapter selection:
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://your-proxy.example.com/v1
# ANTHROPIC_BASE_URL=https://your-anthropic-proxy.example.com
