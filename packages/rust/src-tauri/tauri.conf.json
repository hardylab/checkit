{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CheckIt",
  "version": "0.1.0",
  "identifier": "com.checkit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:ui",
    "beforeBuildCommand": "pnpm build:ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CheckIt - 最佳实践数字化引擎",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "CheckIt - Best Practice Digitalization Engine",
    "longDescription": "CheckIt is a best practice digitalization engine that helps teams ensure their practices always follow best principles."
  }
}
